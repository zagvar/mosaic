{
  "name": "@zagvar/mosaic-core",
  "version": "0.3.0",
  "description": "Framework-free utilities and schemas for Mosaic trading components.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\" && tsc -p tsconfig.json",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "keywords": [
    "trading",
    "stocks",
    "crypto",
    "order-book",
    "validation"
  ],
  "author": "zayau",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zagvar/mosaic.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/zagvar/mosaic#readme",
  "bugs": {
    "url": "https://github.com/zagvar/mosaic/issues"
  },
  "dependencies": {
    "@zagvar/decimal": "^0.1.2",
    "zod": "^4.4.3"
  }
}
