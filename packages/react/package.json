{
  "name": "@zagvar/mosaic-react",
  "version": "0.4.0",
  "description": "Accessible React components for Mosaic trading interfaces.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\" && tsc -p tsconfig.build.json",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@zagvar/decimal": "^0.1.2",
    "@zagvar/mosaic-core": "workspace:*",
    "react-aria-components": "^1.19.0"
  },
  "peerDependencies": {
    "lightweight-charts": ">=5.2 <6",
    "react": ">=18.3 <20",
    "react-dom": ">=18.3 <20"
  },
  "peerDependenciesMeta": {
    "lightweight-charts": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "lightweight-charts": "^5.2.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "keywords": [
    "trading",
    "react",
    "accessibility",
    "order-entry",
    "order-book"
  ],
  "author": "zayau",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zagvar/mosaic.git",
    "directory": "packages/react"
  },
  "homepage": "https://github.com/zagvar/mosaic#readme",
  "bugs": {
    "url": "https://github.com/zagvar/mosaic/issues"
  }
}
